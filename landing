<script>
(function(){
  const t = document.getElementById('giant-track');
  const base = t.innerHTML;
  let content = base;
  while (t.scrollWidth < window.innerWidth * 1.3) {
    content += base;
    t.innerHTML = content;
  }
  t.innerHTML += t.innerHTML;
})();

function buildMarquee(){
  const t=document.getElementById('marquee-track');
  const base=t.dataset.base||(t.dataset.base=t.innerHTML);
  let half=base;
  t.innerHTML=half;
  while(t.scrollWidth < window.innerWidth*1.2){ half+=base; t.innerHTML=half; }
  half+=base;
  t.innerHTML=half+half;
}
buildMarquee();
let rt; window.addEventListener('resize',()=>{ clearTimeout(rt); rt=setTimeout(buildMarquee,200); },{passive:true});

const words=['automate','digitalise','document','simplify'];
let wi=0;
const rot=document.getElementById('rotator');
setInterval(()=>{
  rot.style.transition='opacity .35s';
  rot.style.opacity=0;
  setTimeout(()=>{ wi=(wi+1)%words.length; rot.textContent=words[wi]; rot.style.opacity=1; },380);
},3200);

const st=document.getElementById('statement-text');
st.innerHTML=st.textContent.split(' ').map(w=>`<span class="w">${w}</span>`).join(' ');
const ws=[...st.querySelectorAll('.w')];
function lightWords(){
  const r=st.getBoundingClientRect();
  const p=Math.min(1,Math.max(0,(window.innerHeight*0.85-r.top)/(r.height+window.innerHeight*0.35)));
  const n=Math.floor(p*ws.length);
  ws.forEach((w,i)=>w.classList.toggle('lit',i<n));
}
window.addEventListener('scroll',lightWords,{passive:true}); lightWords();

const io=new IntersectionObserver(es=>{
  es.forEach(e=>{ if(e.isIntersecting){ e.target.classList.add('visible'); io.unobserve(e.target);} });
},{threshold:0.1});
document.querySelectorAll('.reveal').forEach(el=>io.observe(el));
</script>


