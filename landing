<style>
:root{
  --bg:#0a0a0a; --ink:#fafafa; --muted:#a3a3a3; --faint:#5c5c5c;
  --hair:#262626; --maxw:1280px;
  --ease:cubic-bezier(.22,1,.36,1);
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{
